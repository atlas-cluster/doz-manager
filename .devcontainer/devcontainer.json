{
  "name": "Next.js + Docker",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "dockerDashComposeVersion": "v2",
      "moby": false
    }
  },
  "postCreateCommand": "npm install",
  "postStartCommand": "service docker start",
  "forwardPorts": [3000],
  "remoteUser": "node"
}
